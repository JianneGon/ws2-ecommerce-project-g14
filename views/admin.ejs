<h1 class="page-title">Admin Dashboard</h1>
<p style="text-align:center;">Welcome, <%= currentUser.firstName %> (<%= currentUser.role %>)</p>

<div class="table-container">
  <table>
    <thead>
      <tr>
        <th>User ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>Email Verified</th>
        <th>Role</th>
        <th>Status</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(user => { %>
        <tr>
          <td><%= user.userId %></td>
          <td><%= user.firstName %> <%= user.lastName %></td>
          <td><%= user.email %></td>
          <td><%= user.isEmailVerified ? "Yes" : "No" %></td>
          <td><%= user.role %></td>
          <td><%= user.accountStatus %></td>
          <td><%= user.createdAt.toLocaleDateString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="form-buttons">
  <a href="/users/dashboard" class="btn-cancel">Back to Dashboard</a>
</div>
